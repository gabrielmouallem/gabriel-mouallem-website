---
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "@fontsource/caveat/400.css";
import "@fontsource/caveat/600.css";
import "../styles/global.css";
import Hero from "../components/Hero.tsx";
import { SITE } from "../data/site";
import { withBase } from "../lib/base";
---

<html lang="en" data-palette-mode="dark">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" href={withBase("/favicon.ico")} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={SITE.description} />
    <meta name="theme-color" content="#020308" />
    <title>{SITE.name}</title>
    {/* Resolve the palette mode before first paint to avoid a flash:
        an explicit stored choice wins, otherwise default to dark (the OS
        preference is intentionally ignored). The matching <html> attribute
        + theme-color are set synchronously so CSS variables are correct on
        load. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("palette-mode");
          var mode = stored === "light" || stored === "dark" ? stored : "dark";
          document.documentElement.dataset.paletteMode = mode;
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute("content", mode === "light" ? "#e9e6df" : "#020308");
        } catch (e) {
          document.documentElement.dataset.paletteMode = "dark";
        }
      })();
    </script>
  </head>
  <body>
    {/* ── BACKGROUND: static scratch texture ──────────────────────────
        Near-black scanned surface with fine diagonal scratches + dust,
        plus a soft scrim on top for text contrast. Both layers are
        theme-aware (see global.css): in light mode the texture is
        inverted + desaturated to a B&W paper grain and the scrim flips
        to a light wash. */}
    <div aria-hidden="true" class="bg-texture"></div>
    <div aria-hidden="true" class="bg-scrim"></div>

    {/* ── NOISE GRAIN OVERLAY (ElevenLabs technique) ──────────────────
        A 256px noise PNG tiled with `image-rendering:pixelated` and
        `mix-blend-mode:overlay`. Overlay lightens on bright noise and
        darkens on dark noise, embossing a fine fabric-like grain onto
        the bg. 128px tile on retina keeps the grain crisp. */}
    <div aria-hidden="true" class="noise-overlay"></div>
    <div aria-hidden="true" class="noise-grain"></div>

    <Hero client:load />

    {/* ── LENS FLARE OVERLAY ──────────────────────────────────────────
        A full-screen lens-flare photo laid over EVERYTHING (incl. the
        hero) and blended `lighten` at low opacity so only its bright
        light streaks add a subtle optical glow without dimming content. */}
    <div aria-hidden="true" class="lens-flare"></div>
  </body>
</html>
