---
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "@fontsource/caveat/400.css";
import "@fontsource/caveat/600.css";
import "../styles/global.css";
import Hero from "../components/Hero.tsx";
import { SITE } from "../data/site";
import { withBase } from "../lib/base";
import { buildPersonSchema, buildWebsiteSchema } from "../lib/structuredData";

// Preload the body (400) + display (700) Space Mono latin subsets that the
// above-the-fold copy uses, so the big hero title swaps to its real face
// sooner (faster LCP). Imported as URLs so the hashed href matches the
// @font-face src Vite emits from the Fontsource CSS — the browser reuses the
// single download instead of fetching twice.
import spaceMono400 from "@fontsource/space-mono/files/space-mono-latin-400-normal.woff2?url";
import spaceMono700 from "@fontsource/space-mono/files/space-mono-latin-700-normal.woff2?url";

const canonical = SITE.url;
const ogImage = new URL(SITE.ogImage.replace(/^\//, ""), SITE.url).href;
const personSchema = buildPersonSchema();
const websiteSchema = buildWebsiteSchema();
---

<html lang="en" data-palette-mode="dark" data-bg="graph">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32.png")} />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preload" href={spaceMono400} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={spaceMono700} as="font" type="font/woff2" crossorigin="anonymous" />

    {/* ── Primary SEO ─────────────────────────────────────────────── */}
    <title>{SITE.pageTitle}</title>
    <meta name="description" content={SITE.description} />
    <meta name="keywords" content={SITE.keywords.join(", ")} />
    <meta name="author" content={SITE.name} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href={withBase("/sitemap-index.xml")} />

    {/* ── Open Graph ──────────────────────────────────────────────── */}
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={SITE.pageTitle} />
    <meta property="og:description" content={SITE.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.title}`} />
    <meta property="profile:first_name" content={SITE.firstName} />
    <meta property="profile:last_name" content={SITE.lastName} />

    {/* ── Twitter / X ─────────────────────────────────────────────── */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={SITE.pageTitle} />
    <meta name="twitter:description" content={SITE.description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${SITE.name} — ${SITE.title}`} />

    <meta name="theme-color" content="#020308" />

    {/* ── Structured data (schema.org) ────────────────────────────── */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    {/* Resolve the palette mode before first paint to avoid a flash:
        an explicit stored choice wins, otherwise default to dark (the OS
        preference is intentionally ignored). The matching <html> attribute
        + theme-color are set synchronously so CSS variables are correct on
        load. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("palette-mode");
          var mode = stored === "light" || stored === "dark" ? stored : "dark";
          document.documentElement.dataset.paletteMode = mode;
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute("content", mode === "light" ? "#e9e6df" : "#020308");
          // TEMP background-pattern comparison: resolve the stored choice
          // (graph | dots | lines | none) before first paint.
          var bg = localStorage.getItem("bg-pattern");
          if (bg === "graph" || bg === "dots" || bg === "lines" || bg === "none") {
            document.documentElement.dataset.bg = bg;
          }
        } catch (e) {
          document.documentElement.dataset.paletteMode = "dark";
        }
      })();
    </script>
  </head>
  <body>
    {/* ── SEO / a11y document header ───────────────────────────────────
        The visible hero is a stylized, animated treatment of the name, so
        the real semantic heading + intro live here (visually hidden but
        exposed to crawlers and screen readers). This gives the page a
        single, descriptive <h1> and surfaces the LATAM / remote-contract
        context the visual design only implies. */}
    <header class="sr-only">
      <h1>Gabriel Mouallem — Product &amp; Software Engineer</h1>
      <p>
        Senior product and software engineer based in Itajubá, Brazil (LATAM),
        available for remote and contract work with US and international teams.
        7+ years building full-stack products with React, Next.js, TypeScript,
        Node.js and Python, plus cloud-native infrastructure on Kubernetes —
        from IoT and AI/computer-vision platforms to a managed PostgreSQL
        database service. Open to nearshore software development, staff
        augmentation and outsourcing engagements.
      </p>
    </header>

    {/* The page sits directly on the solid `--page-bg` (see global.css);
        the former scratch/fabric/noise/lens-flare overlay layers were
        removed for a clean flat background. */}
    <Hero client:load />
  </body>
</html>
