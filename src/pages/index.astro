---
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/global.css";
import Background from "../components/Background.tsx";
import Hero from "../components/Hero.tsx";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Gabriel Mouallem — Product & Software Engineer. Full-stack, Kubernetes, cloud native."
    />
    <meta name="theme-color" content="#14a3d6" />
    <title>Gabriel Mouallem</title>
  </head>
  <body>
    {/* Swap variant + palette in one place. See palettes.ts for the full list.
        variant: 'ribbon' (prism bands on dark) | 'mesh' (organic gradient blobs)
        Light palettes:  botanica · lichen · forestMagic · sunwash · glacial · riso · sumie · pollen · cyanotype · saint
        Dark palettes:   prismaticDispersion · prismaticAurora · prismaticNewton · prismaticCrystal
                       · prismaticOnyx · prismaticSpectrum · bismuthCrystal · holographicCD
                       · auroraBorealis · nebula · plasma · vaporwave · ironEmberDark · cherenkov */}
    <Background client:load variant="ribbon" palette="prismaticSpectrum" />
    <Hero client:load />
  </body>
</html>
